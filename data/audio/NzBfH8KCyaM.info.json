 के रूप में माननीय श्री डॉ. सोमेंद्र तोमर, राज्यमंत्री, ऊर्जा एवं अतिरिक्त ऊर्जा विभाग, उ.प्र. सरकार, विशिष्ट अतिथि के रूप में श्री राजेन्द्र सिंह, राज्य सूचना आयुक्त, उत्तर प्रदेश सूचना आयोग ने भाग लिया। कार्यक्रम में 600 से अधिक छात्र-छात्राओं, शिक्षकों और गणमान्य लोगों ने हिस्सा लिया।\n\nकार्यक्रम का मुख्य उद्देश्य विद्यार्थियों समेत जनमानस में योग के प्रति जागरूकता बढ़ाना और स्वस्थ जीवनशैली को प्रोत्साहित करना था। \n\n#IDY2026​\n #IDY​ \n#InternationalDayOfYoga2026​ \n#Yoga365​ \n #InternationalDayOfYoga\n​ #PublicHealth\n​ #TraditionalMedicine​ \n#HealthForAll​ \n#AyushForAll​", "channel_id": "UC9T6I5j1xMFxxQG1CSKqntQ", "channel_url": "https://www.youtube.com/channel/UC9T6I5j1xMFxxQG1CSKqntQ", "duration": 144, "view_count": 509, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=NzBfH8KCyaM", "categories": ["People & Blogs"], "tags": ["#IDY2026​", "#IDY", "#InternationalDayOfYoga2026", "#Yoga365", "#InternationalDayOfYoga", "#PublicHealth", "#TraditionalMedicine", "#HealthForAll", "#AyushForAll"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 1, "location": "NASHIK ROAD RAILWAY STATION", "like_count": 21, "channel": "deepak yoga and meditation", "channel_follower_count": 1300, "uploader": "deepak yoga and meditation", "uploader_id": "@sohamchikishalybydeepakma8067", "uploader_url": "https://www.youtube.com/@sohamchikishalybydeepakma8067", "upload_date": "20170127", "timestamp": 1485478743, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "NzBfH8KCyaM", "fulltitle": "Common Yoga Protocol #yoga #yogaday #ayushministry", "duration_string": "2:24", "is_live": false, "was_live": false, "epoch": 1780328872, "format": "136 - 1072x720 (720