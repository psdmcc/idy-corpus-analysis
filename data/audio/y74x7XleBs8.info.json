f Yoga to be celebrated worldwide on 21 June 2016.\n\nAs per guidelines issued by UGC and Ministry of AYUSH, Government of India the International Day of Yoga 2016 is being celebrated at Sri Balaji Vidyapeeth, Pondicherry in a grand manner from 19-21 June 2016. As a prelude to this event, SBV YOGA FEST was celebrated on 25-26 May 2016 to create awareness of Yoga amongst the university student community.", "channel_id": "UC3xQ0l-1CUJMTaUXlfj3zbA", "channel_url": "https://www.youtube.com/channel/UC3xQ0l-1CUJMTaUXlfj3zbA", "duration": 1338, "view_count": 401, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=y74x7XleBs8", "categories": ["Education"], "tags": ["CYTER", "Yoga", "Therapy", "Eduation", "research", "Pondicherry", "health"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 15, "channel": "ISCM of Sri Balaji Vidyapeeth", "channel_follower_count": 11000, "uploader": "ISCM of Sri Balaji Vidyapeeth", "uploader_id": "@ISCMofSriBalajiVidyapeeth", "uploader_url": "https://www.youtube.com/@ISCMofSriBalajiVidyapeeth", "upload_date": "20160607", "timestamp": 1465285590, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "y74x7XleBs8", "fulltitle": "Prof Madanmohan, Director CYTER and Head Physiology talks on Yoga & Lifestyle", "duration_string": "22:18", "is_live": false, "was_live": false, "epoch": 1780331934, "format": "135 - 854x480 (480p)+251 - audio only (medium)", "format_id": "135+251", "ext": "mkv", "protocol": "https+https", "format_note": "480p+medium", "filesize_approx": 146658943, "tbr": 876.781, "width": 854, "height": 480, "resolution": "854x480", "fps": 30, "dynamic_range": "SDR", "vcodec": "avc1.4d401f", "vbr"