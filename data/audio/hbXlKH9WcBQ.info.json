eference": -6, "id": "35"}, {"url": "https://i.ytimg.com/vi/hbXlKH9WcBQ/sddefault.jpg", "height": 480, "width": 640, "preference": -5, "id": "36", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi_webp/hbXlKH9WcBQ/sddefault.webp", "preference": -4, "id": "37"}, {"url": "https://i.ytimg.com/vi/hbXlKH9WcBQ/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/hbXlKH9WcBQ/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/hbXlKH9WcBQ/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/hbXlKH9WcBQ/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/hbXlKH9WcBQ/maxresdefault.jpg", "description": "WIM HOF BREATHING\nExperimenting with Exercise\n80 Breaths \nWim Hof Breathing w/ Lifts & Plyometrics\n\nI did quite a bit with the WHM today.  This is a short video on the exercise stuff I have been doing. \n\nToday I did many rounds of breathing and stretching then wanted to see how the Method Worked with some more muscle taxing lifts. \n\nI did 80 Breaths (no retention)\n\nSPLIT SQUAT 70lbs\n10 Reps each leg \n4 Sets \n50 Breaths in between sets \n\nSINGLE ARM OVERHEAD PRESS 45b KB\n8 Resp on first 2 sets, 6 Reps on last 2 sets\n4 Sets\n50 Breaths in between sets\n\nClose it out with 1 set of \nJUMP LUNGES w/12lb Medicine Ball \n\nMan I was tired and these exercises really tax my muscles.  A split squat is no joke, and at 70lbs that is a lot for me.  I got tired in the press and had to go down to 6 reps. \nThe breathing did not seem to help too much with the reps, I hit muscle fatigue either way.  However, where it did help is in the recovery time.  After 10-15 breaths I was fine, but continued on to the 50 then started again. \n\nWhen it came to the plyometrics (Jump Lunges) this is where the breathing helps.  My cardio was good, it was my quads that started to fail, and after doing 4 sets of split squats I am surprised they lasted for 40 lunges.  \n\nNext workout I will try lighted weights with higher reps, or sprints to see how I fair.  \n\nAfter all of this I had an Ice Bath", "channel_id": "UCiFMSRw4G3JSiniSJYOAVkQ", "channel_url": "https://www.youtube.com/channel/UCiFMSRw4G3JSiniSJYOAVkQ", "duration": 17, "view_count": 447, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=hbXlKH9WcBQ", "categories": ["Education"], "tags": ["Wim Hof", "Steve Mayeda", "TSL Life", "TSL", "TSL Online", "Steve Mayeda Myth of the Alpha Male"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "chapters": [{"start_time": 0, "end_time": 1.0, "title": "<Untitled Chapter 1>"}, {"start_time": 1.0, "title": "80 BREATHS DEEP IN RELAX OUT", "end_time": 7.0}, {"start_time": 7.0, "title": "KETTLE BELL PRESSES 10 EACH ARM 45LBSN 4 SETS", "end_time": 10.0}, {"start_time": 10.0, "title": "40 JUMP LUNGES 12 LB MEDICINE BALL 1 SET AT END OF WORKOUT", "end_time": 17}], "like_count": 2, "channel": "Steve Mayeda", "channel_follower_count": 26800, "uploader": "Steve Mayeda", "uploader_id": "@SteveMayedaTV", "uploader_url": "https://www.youtube.com/@SteveMayedaTV", "upload_date": "20151229", "timestamp": 1451421922, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "hbXlKH9WcBQ", "fulltitle": "WIM HOF BREATHING W/ Exercise Heavier Lifts", "duration_string": "17", "is_live": false, "was_live": false, "epoch": 1780316152, "format": "136 - 1280x720 (720p)+251 - audio only (medium)", "format_id": "136+251", "ext": "mkv", "protocol": "https+https", "format_note": "720p+medium", "filesize_approx": 4334600, "tbr": 2049.6980000000003, "width": 1280, "height": 720, "resolution": "1280x